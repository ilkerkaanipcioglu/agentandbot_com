# GovernanceCore — Environment Variables Template
# Copy this file to .env and fill in your values.
# Local/dev runtime auto-loads this .env file.
# NEVER commit the actual .env file!

# Phoenix secret key — generate with: mix phx.gen.secret
SECRET_KEY_BASE=your_64_char_secret_key_here

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///governance_core_dev.db

# Phoenix host configuration
PHX_HOST=localhost
PORT=4001

# Jules API Key (for GitHub Actions automation)
# Get from: https://jules.google.com
JULES_API_KEY=your_jules_api_key_here

# Gemini image generation
# Server default key. Users may also bring their own key per generation request.
GEMINI_API_KEY=your_gemini_api_key_here
AGENT_IMAGE_ALLOWED_USERS=admin@agentandbot.com,admin@harezm.com
