# GovernanceCore — Environment Variables
# Copy this file to .env and fill in the values.

# --- Server ---
PHX_SERVER=true
PHX_HOST=localhost
PORT=4000
SECRET_KEY_BASE=change_me_use_mix_phx_gen_secret
DATABASE_URL=ecto://postgres:postgres@localhost:5432/governance_core_dev

# --- LLM Providers ---
# Default: ollama | openai | anthropic
LLM_PROVIDER=ollama
LLM_SUMMARIZE=false

# Ollama (default provider)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=60000

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- LRP Integration (optional) ---
LRP_PUBSUB_SERVER=

# --- Ecto ---
POOL_SIZE=10
ECTO_IPV6=false
