<%!-- agentandbot — Room Interface v4
     Pure inline CSS, no Tailwind dependency conflicts
     3-column layout: sidebar | messages | agents
--%>
<div
  id="room-shell"
  style="
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: row;
  background: #0a0c10;
  color: #e2e8f0;
  font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
  font-size: 14px;
  line-height: 1.5;
  overflow: hidden;
"
>
  <%!-- ==============================================
       LEFT SIDEBAR — 220px fixed
       ============================================== --%>
  <div
    id="room-sidebar"
    style="
    width: 220px;
    min-width: 220px;
    max-width: 220px;
    background: #111318;
    border-right: 1px solid #252b36;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  "
  >
    <%!-- Brand --%>
    <div style="
      padding: 14px 16px;
      border-bottom: 1px solid #252b36;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    ">
      <div style="
        width: 30px; height: 30px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-weight: 900; font-size: 13px; color: white;
        flex-shrink: 0;
      ">
        A
      </div>
      <div>
        <div style="font-family: 'Outfit', sans-serif; font-weight: 800; font-size: 13px; color: #f1f5f9; letter-spacing: -0.2px;">
          agentandbot
        </div>
        <div style="font-size: 10px; color: #6b7280; margin-top: 1px;">Ajan İletişim Merkezi</div>
      </div>
    </div>

    <%!-- Channel list --%>
    <div style="flex: 1; overflow-y: auto; padding: 10px 8px;">
      <div style="
        font-size: 10px; font-weight: 700; color: #6b7280;
        text-transform: uppercase; letter-spacing: 1px;
        padding: 8px 8px 6px; margin-bottom: 2px;
      ">
        Kanallar
      </div>

      <%= for room <- @rooms do %>
        <.link
          patch={~p"/rooms/#{room.id}"}
          style={
            "display: flex; align-items: center; gap: 8px; " <>
            "padding: 8px 10px; border-radius: 6px; margin-bottom: 1px; " <>
            "text-decoration: none; font-size: 13px; font-weight: 500; " <>
            "transition: all 0.15s ease; " <>
            if @active_room && @active_room.id == room.id,
              do:   "background: #1a2035; color: #c7d2fe; border: 1px solid #3730a3;",
              else: "background: transparent; color: #9ca3af; border: 1px solid transparent;"
          }
        >
          <span style={
            "font-size: 16px; font-weight: 700; flex-shrink: 0; " <>
            if @active_room && @active_room.id == room.id,
              do: "color: #818cf8;", else: "color: #4b5563;"
          }>
            #
          </span>
          <span style="flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
            {room.name}
          </span>
          <%= if room.status == "awaiting_approval" do %>
            <span style="width: 7px; height: 7px; border-radius: 50%; background: #a855f7; flex-shrink: 0;">
            </span>
          <% end %>
          <%= if room.status == "paused" do %>
            <span style="width: 7px; height: 7px; border-radius: 50%; background: #f59e0b; flex-shrink: 0;">
            </span>
          <% end %>
        </.link>
      <% end %>

      <%!-- New channel form --%>
      <div style="margin-top: 14px; padding-top: 12px; border-top: 1px solid #252b36;">
        <div style="font-size: 10px; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 1px; padding: 0 4px 8px;">
          Yeni Kanal
        </div>
        <form phx-submit="create_room" style="display: flex; gap: 5px;">
          <input
            type="text"
            name="room[name]"
            placeholder="kanal-adı"
            required
            style="
              flex: 1; min-width: 0;
              background: #0d1117;
              border: 1px solid #2d3748;
              border-radius: 6px;
              padding: 6px 8px;
              font-size: 12px;
              color: #e2e8f0;
              outline: none;
              font-family: inherit;
            "
          />
          <button
            type="submit"
            style="
            background: #4f46e5;
            color: white;
            border: none;
            border-radius: 6px;
            width: 30px;
            font-size: 18px;
            line-height: 1;
            cursor: pointer;
            flex-shrink: 0;
          "
          >
            +
          </button>
        </form>
      </div>
    </div>

    <%!-- User badge at bottom --%>
    <div style="
      padding: 10px 12px;
      border-top: 1px solid #252b36;
      display: flex; align-items: center; gap: 10px;
      background: #0d1117;
      flex-shrink: 0;
    ">
      <div style="
        width: 28px; height: 28px;
        background: #4f46e5;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-weight: 800; font-size: 11px; color: white;
        flex-shrink: 0;
      ">
        U
      </div>
      <div>
        <div style="font-size: 12px; font-weight: 700; color: #f1f5f9;">Operatör</div>
        <div style="font-size: 10px; color: #22c55e; display: flex; align-items: center; gap: 4px;">
          <span style="display: inline-block; width: 5px; height: 5px; border-radius: 50%; background: #22c55e;">
          </span>
          Çevrimiçi
        </div>
      </div>
    </div>
  </div>

  <%!-- ==============================================
       CENTER — Message Stream (fills remaining space)
       ============================================== --%>
  <div
    id="room-center"
    style="
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #0a0c10;
  "
  >
    <%= if @active_room do %>
      <%!-- Top bar --%>
      <div style="
        height: 52px;
        border-bottom: 1px solid #252b36;
        padding: 0 18px;
        display: flex; align-items: center; justify-content: space-between; gap: 12px;
        background: #0a0c10;
        flex-shrink: 0;
      ">
        <div style="display: flex; align-items: center; gap: 10px;">
          <span style="font-size: 20px; color: #4f46e5; font-weight: 900;">#</span>
          <span style="font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 800; color: #f1f5f9;">
            {@active_room.name}
          </span>
          <%= cond do %>
            <% @room_status == :paused -> %>
              <span style="padding: 2px 9px; border-radius: 20px; background: rgba(245,158,11,0.12); color: #f59e0b; border: 1px solid rgba(245,158,11,0.3); font-size: 10px; font-weight: 700;">
                ⏸ Duraklı
              </span>
            <% @room_status == :awaiting_approval -> %>
              <span style="padding: 2px 9px; border-radius: 20px; background: rgba(168,85,247,0.12); color: #c084fc; border: 1px solid rgba(168,85,247,0.3); font-size: 10px; font-weight: 700;">
                🔔 Onay Bekliyor
              </span>
            <% true -> %>
              <span style="padding: 2px 9px; border-radius: 20px; background: rgba(34,197,94,0.1); color: #4ade80; border: 1px solid rgba(34,197,94,0.25); font-size: 10px; font-weight: 700;">
                ● Aktif
              </span>
          <% end %>
        </div>
        <%!-- View toggle --%>
        <div style="display: flex; background: #161b22; border: 1px solid #252b36; border-radius: 8px; padding: 3px; gap: 3px; flex-shrink: 0;">
          <button
            phx-click="toggle_mode"
            phx-value-mode="summary"
            style={
            "border: none; border-radius: 5px; font-size: 11px; font-weight: 700; cursor: pointer; padding: 4px 12px; " <>
            if @view_mode == :summary, do: "background: #4f46e5; color: white;", else: "background: transparent; color: #6b7280;"
          }
          >
            Özet
          </button>
          <button
            phx-click="toggle_mode"
            phx-value-mode="raw"
            style={
            "border: none; border-radius: 5px; font-size: 11px; font-weight: 700; cursor: pointer; padding: 4px 12px; " <>
            if @view_mode == :raw, do: "background: #4f46e5; color: white;", else: "background: transparent; color: #6b7280;"
          }
          >
            Ham MCP
          </button>
          <button
            phx-click="toggle_mode"
            phx-value-mode="tasks"
            style={
            "border: none; border-radius: 5px; font-size: 11px; font-weight: 700; cursor: pointer; padding: 4px 12px; " <>
            if @view_mode == :tasks, do: "background: #4f46e5; color: white;", else: "background: transparent; color: #6b7280;"
          }
          >
            Görev Akışı (DAG)
          </button>
          <button
            phx-click="toggle_mode"
            phx-value-mode="events"
            style={
            "border: none; border-radius: 5px; font-size: 11px; font-weight: 700; cursor: pointer; padding: 4px 12px; " <>
            if @view_mode == :events, do: "background: #4f46e5; color: white;", else: "background: transparent; color: #6b7280;"
          }
          >
            Olay Günlüğü
          </button>
        </div>
      </div>

      <%!-- Stats bar --%>
      <div style="display: flex; border-bottom: 1px solid #252b36; background: #0d1117; flex-shrink: 0;">
        <%= for {label, value, color} <- [
          {"Gecikme", @room_stats.avg_latency, "#e2e8f0"},
          {"Sıkıştırma", @room_stats.compression_ratio, "#818cf8"},
          {"Paket Sayısı", to_string(@room_stats.packets_processed), "#4ade80"},
          {"Son Olay", @room_stats.last_event, "#fbbf24"}
        ] do %>
          <div style="flex: 1; padding: 7px 14px; border-right: 1px solid #252b36; text-align: center;">
            <div style="font-size: 9px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700;">
              {label}
            </div>
            <div style={"font-size: 12px; font-weight: 700; font-family: monospace; margin-top: 2px; color: #{color}; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"}>
              {value}
            </div>
          </div>
        <% end %>
      </div>

      <%!-- Approval banner --%>
      <%= if !Enum.empty?(@pending_approvals) do %>
        <div style="background: rgba(168,85,247,0.07); border-bottom: 1px solid rgba(168,85,247,0.25); padding: 12px 18px; flex-shrink: 0;">
          <div style="font-size: 11px; font-weight: 700; color: #c084fc; margin-bottom: 8px;">
            🔔 Ajan Karar Bekliyor
          </div>
          <%= for req <- @pending_approvals do %>
            <div style="
              background: #111318;
              border: 1px solid rgba(168,85,247,0.3);
              border-radius: 8px;
              padding: 11px 14px;
              display: flex; align-items: center; justify-content: space-between; gap: 14px;
              margin-bottom: 6px;
            ">
              <div style="flex: 1; min-width: 0;">
                <div style="font-size: 11px; color: #6b7280; margin-bottom: 4px;">
                  İsteyen:
                  <strong style="color: #c084fc;">
                    <%= case Enum.find(@agents, &(&1.id == req.agent_id)) do %>
                      <% nil -> %>
                        Agent
                      <% agent -> %>
                        {agent.name}
                    <% end %>
                  </strong>
                </div>
                <p style="font-size: 13px; color: #f1f5f9; font-weight: 500; margin: 0;">
                  {req.description}
                </p>
              </div>
              <div style="display: flex; gap: 6px; flex-shrink: 0;">
                <button
                  phx-click="resolve_approval"
                  phx-value-id={req.id}
                  phx-value-decision="approved"
                  style="padding: 6px 14px; background: #16a34a; color: white; border: none; border-radius: 6px; font-size: 12px; font-weight: 700; cursor: pointer;"
                >
                  Onayla
                </button>
                <button
                  phx-click="resolve_approval"
                  phx-value-id={req.id}
                  phx-value-decision="rejected"
                  style="padding: 6px 14px; background: #dc2626; color: white; border: none; border-radius: 6px; font-size: 12px; font-weight: 700; cursor: pointer;"
                >
                  Reddet
                </button>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <%= cond do %>
        <% @view_mode in [:summary, :raw] -> %>
          <%!-- Messages --%>
          <div
            id="messages-container"
            phx-update="stream"
            style="
          flex: 1;
          overflow-y: auto;
          padding: 14px 18px;
          display: flex;
          flex-direction: column;
          gap: 3px;
          min-height: 0;
        "
          >
            <div
              id="messages-empty-state"
              class="hidden only:block"
              style="
            text-align: center; padding: 60px 20px;
            color: #4b5563;
          "
            >
              <div style="font-size: 40px; margin-bottom: 14px;">⚡</div>
              <div style="font-size: 14px; font-weight: 600; color: #6b7280; margin-bottom: 6px;">
                Kanal hazır
              </div>
              <div style="font-size: 12px; color: #4b5563;">
                Sağ panelden ajan davet et veya "Demo Başlat" düğmesine bas.
              </div>
            </div>

            <div
              :for={{id, message} <- @streams.messages}
              id={id}
              style={
              "padding: 10px 14px; border-radius: 8px; border-left: 3px solid; " <>
              if message.from_type == "human",
                do: "background: rgba(34,197,94,0.05); border-left-color: #16a34a;",
                else: "background: rgba(99,102,241,0.05); border-left-color: #4f46e5;"
            }
            >
              <%!-- Header row --%>
              <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 6px;">
                <%!-- Avatar --%>
                <div style={
                "width: 22px; height: 22px; border-radius: 50%; " <>
                "display: flex; align-items: center; justify-content: center; " <>
                "font-size: 10px; font-weight: 800; flex-shrink: 0; " <>
                if message.from_type == "human",
                  do: "background: #16a34a; color: white;",
                  else: "background: #4f46e5; color: white;"
              }>
                  <%= if message.from_type == "human" do %>
                    U
                  <% else %>
                    <%= case Enum.find(@agents, &(&1.id == message.from_id)) do %>
                      <% nil -> %>
                        ?
                      <% agent -> %>
                        {String.at(agent.name, 0) |> String.upcase()}
                    <% end %>
                  <% end %>
                </div>
                <%!-- Name --%>
                <span style={
                "font-size: 13px; font-weight: 700; " <>
                if message.from_type == "human", do: "color: #4ade80;", else: "color: #818cf8;"
              }>
                  <%= if message.from_type == "human" do %>
                    Operatör
                  <% else %>
                    <%= case Enum.find(@agents, &(&1.id == message.from_id)) do %>
                      <% nil -> %>
                        Ajan
                      <% agent -> %>
                        {agent.name}
                    <% end %>
                  <% end %>
                </span>
                <%= if message.from_type != "human" do %>
                  <% agent = Enum.find(@agents, &(&1.id == message.from_id)) %>
                  <%= if agent do %>
                    <span style="font-size: 10px; color: #6b7280; background: #1e2530; padding: 1px 6px; border-radius: 4px;">
                      {agent.role}
                    </span>
                  <% end %>
                <% end %>
                <%!-- Timestamp --%>
                <span style="font-size: 10px; color: #374151; font-family: monospace; margin-left: auto;">
                  {Calendar.strftime(message.inserted_at || DateTime.utc_now(), "%H:%M:%S")}
                </span>
              </div>
              <%!-- Body --%>
              <div style="padding-left: 30px;">
                <%= if @view_mode == :summary do %>
                  <%= if message.summary && message.summary != "" do %>
                    <p style="font-size: 13px; color: #cbd5e1; line-height: 1.6; margin: 0;">
                      {message.summary}
                    </p>
                  <% else %>
                    <span style="font-size: 12px; color: #4b5563; font-style: italic;">
                      ⏳ Özet oluşturuluyor...
                    </span>
                  <% end %>
                <% else %>
                  <pre style="
                  background: #0d1117; border: 1px solid #252b36; border-radius: 6px;
                  padding: 10px; font-size: 11px; font-family: monospace;
                  color: #a5b4fc; overflow-x: auto; white-space: pre-wrap; margin: 0;
                ">{Jason.encode!(message.payload, pretty: true)}</pre>
                <% end %>
              </div>
            </div>
          </div>
        <% @view_mode == :tasks -> %>
          <%!-- DAG Visualizer --%>
          <div
            id="tasks-container"
            style="
            flex: 1;
            overflow-y: auto;
            padding: 14px 18px;
            display: flex;
            flex-direction: column;
            gap: 14px;
            min-height: 0;
          "
          >
            <style>
              @keyframes pulse {
                0%, 100% { opacity: 1; }
                50% { opacity: 0.5; }
              }
            </style>
            <div style="font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 800; color: #f1f5f9; margin-bottom: 4px; display: flex; align-items: center; justify-content: space-between;">
              <span>Görev Grafiği (DAG)</span>
              <span style="font-size: 11px; font-weight: 600; color: #6b7280; background: #161b22; padding: 2px 8px; border-radius: 6px; border: 1px solid #252b36;">
                Toplam: {length(@room_tasks)} Görev
              </span>
            </div>

            <%= if Enum.empty?(@room_tasks) do %>
              <div
                id="tasks-empty-state"
                style="
                text-align: center; padding: 60px 20px;
                color: #4b5563;
              "
              >
                <div style="font-size: 40px; margin-bottom: 14px;">⛓</div>
                <div style="font-size: 14px; font-weight: 600; color: #6b7280; margin-bottom: 6px;">
                  Görev Akışı Boş
                </div>
                <div style="font-size: 12px; color: #4b5563;">
                  Ajanlar delege ettikçe görevler burada hiyerarşik olarak belirecektir.
                </div>
              </div>
            <% else %>
              <%!-- Render roots --%>
              <.task_tree tasks={@room_tasks} parent_id={nil} depth={0} agents={@agents} />
            <% end %>
          </div>
        <% true -> %>
          <%!-- Event Log Filter Bar --%>
          <div
            id="event-filters-bar"
            style="
          padding: 10px 18px;
          background: #111318;
          border-bottom: 1px solid #252b36;
          display: flex;
          align-items: center;
          gap: 12px;
          flex-wrap: wrap;
          flex-shrink: 0;
        "
          >
            <%!-- Search Form --%>
            <form
              phx-change="search_events"
              phx-submit="search_events"
              style="display: flex; flex: 1; min-width: 200px;"
            >
              <input
                type="text"
                name="search"
                value={@event_search}
                placeholder="Olay ara (trace, span, tip)..."
                style="
                width: 100%;
                background: #0d1117;
                border: 1px solid #2d3748;
                border-radius: 6px;
                padding: 6px 12px;
                font-size: 12px;
                color: #e2e8f0;
                outline: none;
                font-family: inherit;
              "
              />
            </form>

            <%!-- Event Type Dropdown --%>
            <form phx-change="filter_event_type" style="display: flex;">
              <select
                name="type"
                style="
                background: #0d1117;
                border: 1px solid #2d3748;
                border-radius: 6px;
                padding: 6px 10px;
                font-size: 12px;
                color: #e2e8f0;
                outline: none;
                font-family: inherit;
                cursor: pointer;
              "
              >
                <option value="all">Tüm Olay Tipleri</option>
                <%= for type <- ["agent_connected", "agent_disconnected", "message_sent", "tool_call_started", "tool_call_completed", "tool_call_failed", "approval_requested", "approval_granted", "approval_rejected", "room_paused", "room_resumed"] do %>
                  <option value={type} selected={@event_filters.event_type == type}>
                    {type}
                  </option>
                <% end %>
              </select>
            </form>

            <%!-- Agent Dropdown --%>
            <form phx-change="filter_agent" style="display: flex;">
              <select
                name="agent_id"
                style="
                background: #0d1117;
                border: 1px solid #2d3748;
                border-radius: 6px;
                padding: 6px 10px;
                font-size: 12px;
                color: #e2e8f0;
                outline: none;
                font-family: inherit;
                cursor: pointer;
              "
              >
                <option value="all">Tüm Ajanlar</option>
                <%= for agent <- @agents do %>
                  <option value={agent.id} selected={@event_filters.agent_id == agent.id}>
                    {agent.name}
                  </option>
                <% end %>
              </select>
            </form>

            <%!-- Active filter badges & Clear --%>
            <%= if @event_filters.agent_id || @event_filters.event_type || @event_filters.trace_id || (@event_search != "") do %>
              <button
                type="button"
                phx-click="clear_event_filters"
                style="
                background: rgba(239, 68, 68, 0.1);
                color: #f87171;
                border: 1px solid rgba(239, 68, 68, 0.25);
                border-radius: 6px;
                padding: 6px 12px;
                font-size: 12px;
                font-weight: 600;
                cursor: pointer;
                display: flex;
                align-items: center;
                gap: 4px;
              "
              >
                Clear Filters
              </button>
            <% end %>
          </div>

          <%!-- Event Log Timeline --%>
          <div
            id="events-container"
            phx-update="stream"
            style="
          flex: 1;
          overflow-y: auto;
          padding: 14px 18px;
          display: flex;
          flex-direction: column;
          gap: 8px;
          min-height: 0;
        "
          >
            <div
              id="events-empty-state"
              class="hidden only:block"
              style="
            text-align: center; padding: 60px 20px;
            color: #4b5563;
          "
            >
              <div style="font-size: 40px; margin-bottom: 14px;">📋</div>
              <div style="font-size: 14px; font-weight: 600; color: #6b7280; margin-bottom: 6px;">
                Olay günlüğü temiz
              </div>
              <div style="font-size: 12px; color: #4b5563;">
                Henüz bir tracing veya denetim olayı kaydedilmedi.
              </div>
            </div>

            <div
              :for={{id, event} <- @streams.agent_events}
              id={id}
              style={
              "background: " <> (if @event_filters.trace_id == event.trace_id, do: "rgba(99, 102, 241, 0.06);", else: "#111318;") <> " " <>
              "border: 1px solid " <> (if @event_filters.trace_id == event.trace_id, do: "rgba(99, 102, 241, 0.4);", else: "#252b36;") <> " " <>
              "border-radius: 8px; " <>
              "padding: 12px 14px; " <>
              "display: flex; " <>
              "flex-direction: column; " <>
              "gap: 8px; " <>
              "transition: all 0.2s ease; " <>
              if(@event_filters.trace_id && event.parent_span_id, do: "margin-left: 24px; border-left: 3px solid #8b5cf6;", else: "")
            }
            >
              <%!-- Header row --%>
              <div style="display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
                <%!-- Status badge (color coded by event type, clickable) --%>
<%= {bg, fg, border} = event_status_color(event.event_type) %>
                <span
                  phx-click="filter_event_type"
                  phx-value-type={event.event_type}
                  style={"font-size: 10px; font-weight: 800; text-transform: uppercase; padding: 2px 8px; border-radius: 4px; cursor: pointer; transition: opacity 0.15s; background: #{bg}; color: #{fg}; border: 1px solid #{border};"}
                  onmouseover="this.style.opacity='0.8'"
                  onmouseout="this.style.opacity='1.0'"
                >
                  {EventTaxonomy.label(event.event_type)}
                </span>

                <%!-- Agent Name (clickable filter) --%>
                <span
                  phx-click={if event.agent_id, do: "filter_agent", else: nil}
                  phx-value-agent_id={event.agent_id}
                  style={
                  "font-size: 13px; font-weight: 700; " <>
                  if(event.agent_id, do: "color: #cbd5e1; cursor: pointer; text-decoration: underline dashed 1px #4b5563;", else: "color: #6b7280;")
                }
                >
                  <%= if event.agent_id do %>
                    <%= case Enum.find(@agents, &(&1.id == event.agent_id)) do %>
                      <% nil -> %>
                        Ajan ({String.slice(event.agent_id, 0, 8)})
                      <% agent -> %>
                        {agent.name}
                    <% end %>
                  <% else %>
                    Sistem / Operatör
                  <% end %>
                </span>

                <%!-- Latency Badge --%>
                <%= if event.duration_ms do %>
                  <span style="
                  font-size: 10px;
                  font-weight: 700;
                  font-family: monospace;
                  padding: 2px 6px;
                  border-radius: 4px;
                  background: rgba(16, 185, 129, 0.12);
                  color: #34d399;
                  border: 1px solid rgba(16, 185, 129, 0.2);
                ">
                    ⏱ {event.duration_ms}ms
                  </span>
                <% end %>

                <%!-- IDs (Trace and Span, clickable filter) --%>
                <div style="font-size: 11px; font-family: monospace; color: #4b5563; display: flex; gap: 8px; align-items: center;">
                  <span>
                    trace:
                    <span
                      phx-click="filter_trace"
                      phx-value-trace_id={event.trace_id}
                      style="
                      color: #818cf8;
                      cursor: pointer;
                      background: rgba(99, 102, 241, 0.1);
                      padding: 1px 5px;
                      border-radius: 4px;
                      border: 1px solid rgba(99, 102, 241, 0.2);
                    "
                      onmouseover="this.style.background='rgba(99, 102, 241, 0.2)'"
                      onmouseout="this.style.background='rgba(99, 102, 241, 0.1)'"
                    >
                      {String.slice(event.trace_id, 0, 8)}
                    </span>
                  </span>
                  <span>
                    span:
                    <span style="color: #10b981; background: rgba(16, 185, 129, 0.08); padding: 1px 5px; border-radius: 4px;">
                      {String.slice(event.span_id, 0, 8)}
                    </span>
                  </span>
                  <%= if event.parent_span_id do %>
                    <span>
                      parent:
                      <span
                        phx-click="filter_trace"
                        phx-value-trace_id={event.trace_id}
                        style="color: #f59e0b; background: rgba(245, 158, 11, 0.08); padding: 1px 5px; border-radius: 4px; cursor: pointer;"
                      >
                        {String.slice(event.parent_span_id, 0, 8)}
                      </span>
                    </span>
                  <% end %>
                </div>

                <%!-- Timestamp --%>
                <span style="font-size: 11px; color: #4b5563; font-family: monospace; margin-left: auto;">
                  {Calendar.strftime(event.inserted_at || DateTime.utc_now(), "%H:%M:%S")}
                </span>
              </div>

              <%!-- Collapsible payload --%>
              <details style="margin-top: 4px;">
                <summary style="
                font-size: 11px; font-weight: 700; color: #6b7280;
                cursor: pointer; user-select: none;
                display: flex; align-items: center; gap: 4px;
                outline: none;
              ">
                  <span>Payload Göster/Gizle</span>
                </summary>
                <pre style="
                margin-top: 6px;
                background: #0d1117;
                border: 1px solid #252b36;
                border-radius: 6px;
                padding: 10px;
                font-size: 11px;
                font-family: monospace;
                color: #a5b4fc;
                overflow-x: auto;
                white-space: pre-wrap;
                margin: 0;
              ">{Jason.encode!(event.payload, pretty: true)}</pre>
              </details>
            </div>
          </div>
      <% end %>

      <%!-- Input bar --%>
      <div style="
        padding: 12px 18px;
        border-top: 1px solid #252b36;
        background: #0a0c10;
        flex-shrink: 0;
      ">
        <form
          phx-submit="send_message"
          id="room-input-form"
          style="display: flex; gap: 8px; align-items: center;"
        >
          <%!-- Pause/Resume --%>
          <%= if @room_status == :paused do %>
            <button
              type="button"
              phx-click="resume"
              title="Devam ettir"
              style="
              width: 38px; height: 38px; border-radius: 8px;
              background: #d97706; border: none; color: white;
              font-size: 15px; cursor: pointer; flex-shrink: 0;
            "
            >
              ▶
            </button>
          <% else %>
            <button
              type="button"
              phx-click="pause"
              title="Duraklat"
              style="
              width: 38px; height: 38px; border-radius: 8px;
              background: #1e2530; border: 1px solid #374151; color: #6b7280;
              font-size: 14px; cursor: pointer; flex-shrink: 0;
            "
            >
              ⏸
            </button>
          <% end %>
          <input
            type="text"
            name="message[text]"
            id="room-input-box"
            placeholder="Ajanlara mesaj veya komut yaz..."
            required
            style="
              flex: 1; background: #111318; border: 1px solid #2d3748;
              border-radius: 8px; padding: 9px 14px;
              font-size: 13px; color: #e2e8f0; outline: none; font-family: inherit;
            "
          />
          <button
            type="submit"
            style="
            padding: 9px 18px; background: #4f46e5; color: white;
            border: none; border-radius: 8px; font-size: 13px; font-weight: 700;
            cursor: pointer; flex-shrink: 0;
          "
          >
            Gönder
          </button>
        </form>
      </div>
    <% else %>
      <div style="flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px; text-align: center;">
        <div style="font-size: 48px; margin-bottom: 16px; color: #374151;">#</div>
        <h3 style="font-family: 'Outfit', sans-serif; font-size: 18px; font-weight: 800; color: #f1f5f9; margin: 0 0 8px;">
          Kanal Seçilmedi
        </h3>
        <p style="font-size: 13px; color: #6b7280; margin: 0;">
          Soldan bir kanal seç veya yeni bir tane oluştur.
        </p>
      </div>
    <% end %>
  </div>

  <%!-- ==============================================
       RIGHT PANEL — 250px fixed
       ============================================== --%>
  <div
    id="room-agents"
    style="
    width: 250px;
    min-width: 250px;
    max-width: 250px;
    background: #111318;
    border-left: 1px solid #252b36;
    display: flex;
    flex-direction: column;
    overflow-y: auto;
  "
  >
      <%!-- Agents in room --%>
    <div style="padding: 14px 14px 0; flex-shrink: 0;">
      <div style="font-size: 10px; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; display: flex; align-items: center; justify-content: space-between;">
        <span>Odadaki Ajanlar ({length(@room_agents)})</span>
        <span style="font-size: 9px; font-weight: 600; color: #4ade80; background: rgba(34,197,94,0.08); padding: 2px 6px; border-radius: 4px; border: 1px solid rgba(34,197,94,0.15);">
          ● {length(Enum.filter(@room_agents, &(&1.status == "active")))} Aktif
        </span>
      </div>
      <%= if Enum.empty?(@room_agents) do %>
        <div style="font-size: 12px; color: #4b5563; font-style: italic; padding: 12px; border: 1px dashed #252b36; border-radius: 6px; text-align: center;">
          Henüz ajan yok
        </div>
      <% else %>
        <%= for agent <- @room_agents do %>
          <div style="background: #161b22; border: 1px solid #252b36; border-radius: 8px; padding: 10px; margin-bottom: 6px; position: relative;">
            <div style="display: flex; align-items: center; gap: 8px;">
              <div style="
                width: 32px; height: 32px; border-radius: 50%;
                background: linear-gradient(135deg, #4f46e5, #7c3aed);
                display: flex; align-items: center; justify-content: center;
                font-weight: 800; font-size: 13px; color: white; flex-shrink: 0;
                position: relative;
              ">
                {String.at(agent.name, 0) |> String.upcase()}
                <%!-- Online status dot --%>
                <span style={
                  "position: absolute; bottom: -1px; right: -1px; width: 10px; height: 10px; border-radius: 50%; border: 2px solid #161b22; " <>
                  case agent.status do
                    "active" -> "background: #22c55e;"
                    "paused" -> "background: #f59e0b;"
                    "safety_shutdown" -> "background: #ef4444;"
                    _ -> "background: #6b7280;"
                  end
                }>
                </span>
              </div>
              <div style="flex: 1; min-width: 0;">
                <div style="font-size: 12px; font-weight: 700; color: #f1f5f9; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: flex; align-items: center; gap: 6px;">
                  {agent.name}
                  <%!-- Protocol badge --%>
                  <span style={
                    "font-size: 8px; font-weight: 700; padding: 1px 5px; border-radius: 3px; flex-shrink: 0; " <>
                    case agent.protocol do
                      "ABL.ONE/1.0" -> "background: rgba(99,102,241,0.12); color: #818cf8; border: 1px solid rgba(99,102,241,0.25);"
                      "MCP/1.0" -> "background: rgba(34,197,94,0.12); color: #4ade80; border: 1px solid rgba(34,197,94,0.25);"
                      "A2A/1.0" -> "background: rgba(168,85,247,0.12); color: #c084fc; border: 1px solid rgba(168,85,247,0.25);"
                      _ -> "background: rgba(107,114,128,0.12); color: #9ca3af; border: 1px solid rgba(107,114,128,0.25);"
                    end
                  }>
                    {agent.protocol}
                  </span>
                </div>
                <div style="font-size: 10px; color: #6b7280; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: flex; align-items: center; gap: 6px;">
                  <span>{agent.role}</span>
                  <span style="color: #374151;">·</span>
                  <span style={
                    case agent.status do
                      "active" -> "color: #4ade80;"
                      "paused" -> "color: #f59e0b;"
                      "safety_shutdown" -> "color: #f87171;"
                      _ -> "color: #9ca3af;"
                    end
                  }>
                    <%= case agent.status do %>
                      <% "active" -> %>Aktif
                      <% "paused" -> %>Duraklı
                      <% "safety_shutdown" -> %>Kilitli
                      <% s -> %>{s}
                    <% end %>
                  </span>
                </div>
              </div>
            </div>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-top: 8px; padding-top: 8px; border-top: 1px solid #252b36;">
              <span style="font-size: 10px; color: #6b7280;">
                Lv<strong style="color: #e2e8f0;">{agent.level}</strong>
              </span>
              <span style="font-size: 10px; color: #4ade80;">⭐ {agent.trust_score}</span>
              <%= if agent.last_seen do %>
                <span style="font-size: 9px; color: #374151; font-family: monospace;">
                  {Calendar.strftime(agent.last_seen, "%H:%M")}
                </span>
              <% end %>
              <button
                phx-click="leave_agent"
                phx-value-agent_id={agent.id}
                style="font-size: 10px; color: #f87171; background: none; border: none; cursor: pointer; font-weight: 600; padding: 2px 4px;"
              >
                Çıkar
              </button>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <%!-- Pipeline topology --%>
    <%= if !Enum.empty?(@room_agents) do %>
      <div style="padding: 10px 14px; flex-shrink: 0;">
        <div style="font-size: 10px; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px;">
          İletişim Zinciri
        </div>
        <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 4px;">
          <%= for {agent, idx} <- Enum.with_index(@room_agents) do %>
            <%= if idx > 0 do %>
              <span style="color: #4f46e5; font-size: 12px;">→</span>
            <% end %>
            <span style="font-size: 10px; padding: 2px 7px; border-radius: 4px; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.25); color: #a5b4fc; font-weight: 600;">
              {agent.name}
            </span>
          <% end %>
          <%= if @room_status == :awaiting_approval do %>
            <span style="color: #a855f7; font-size: 12px;">→</span>
            <span style="font-size: 10px; padding: 2px 7px; border-radius: 4px; background: rgba(168,85,247,0.12); border: 1px solid rgba(168,85,247,0.3); color: #d8b4fe; font-weight: 700;">
              ONAY
            </span>
          <% end %>
        </div>
      </div>
    <% end %>

    <%!-- Invite agent --%>
    <div style="padding: 0 14px; flex-shrink: 0;">
      <div style="border-top: 1px solid #252b36; padding-top: 12px;">
        <div style="font-size: 10px; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px;">
          Ajan Davet Et
        </div>
        <div style="max-height: 160px; overflow-y: auto; background: #161b22; border: 1px solid #252b36; border-radius: 8px; padding: 4px;">
          <%= for agent <- @agents do %>
            <%= if not Enum.any?(@room_agents, &(&1.id == agent.id)) do %>
              <button
                phx-click="join_agent"
                phx-value-agent_id={agent.id}
                style="
                display: flex; align-items: center; gap: 8px;
                padding: 7px 8px; border-radius: 5px;
                background: none; border: none; cursor: pointer;
                width: 100%; text-align: left;
                transition: background 0.1s;
              "
                onmouseover="this.style.background='#1e2530'"
                onmouseout="this.style.background='transparent'"
              >
                <span style="width: 6px; height: 6px; border-radius: 50%; background: #4f46e5; flex-shrink: 0;">
                </span>
                <span style="font-size: 12px; font-weight: 600; color: #9ca3af; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {agent.name}
                </span>
                <span style="font-size: 10px; color: #4b5563;">
                  {String.slice(agent.role, 0, 12)}
                </span>
              </button>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

    <%!-- Demo controls --%>
    <%= if @active_room && !Enum.empty?(@room_agents) do %>
      <div style="padding: 12px 14px; margin-top: 8px; border-top: 1px solid #252b36; flex-shrink: 0;">
        <div style="font-size: 10px; font-weight: 700; color: #6b7280; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px;">
          Demo Simülatörü
        </div>
        <button
          phx-click="run_autonomous_demo"
          style="
          width: 100%; padding: 9px; background: #4f46e5; color: white;
          border: none; border-radius: 8px; font-size: 12px; font-weight: 700;
          cursor: pointer; margin-bottom: 10px;
        "
        >
          ⚡ Ajan Sürüsünü Başlat
        </button>
        <div style="font-size: 10px; color: #4b5563; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px;">
          Manuel Olay
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5px;">
          <button
            phx-click="inject_agent_mcp"
            phx-value-agent_id={List.first(@room_agents).id}
            phx-value-type="init"
            style="padding: 7px 4px; background: #161b22; border: 1px solid #2d3748; border-radius: 6px; font-size: 10px; font-weight: 600; color: #9ca3af; cursor: pointer; text-align: center;"
          >
            🔌 Bağlan
          </button>
          <button
            phx-click="inject_agent_mcp"
            phx-value-agent_id={List.first(@room_agents).id}
            phx-value-type="tool_call"
            style="padding: 7px 4px; background: #161b22; border: 1px solid #2d3748; border-radius: 6px; font-size: 10px; font-weight: 600; color: #9ca3af; cursor: pointer; text-align: center;"
          >
            🛠 Araç
          </button>
          <button
            phx-click="inject_agent_mcp"
            phx-value-agent_id={List.first(@room_agents).id}
            phx-value-type="result"
            style="padding: 7px 4px; background: #161b22; border: 1px solid #2d3748; border-radius: 6px; font-size: 10px; font-weight: 600; color: #9ca3af; cursor: pointer; text-align: center;"
          >
            ✅ Sonuç
          </button>
          <button
            phx-click="inject_agent_mcp"
            phx-value-agent_id={List.first(@room_agents).id}
            phx-value-type="approval"
            style="padding: 7px 4px; background: rgba(168,85,247,0.1); border: 1px solid rgba(168,85,247,0.3); border-radius: 6px; font-size: 10px; font-weight: 700; color: #c084fc; cursor: pointer; text-align: center;"
          >
            🔔 Onay
          </button>
          <button
            phx-click="inject_agent_mcp"
            phx-value-agent_id={List.first(@room_agents).id}
            phx-value-type="delegate"
            style="padding: 7px 4px; background: #161b22; border: 1px solid #2d3748; border-radius: 6px; font-size: 10px; font-weight: 600; color: #9ca3af; cursor: pointer; text-align: center;"
          >
            ⛓ Delege Et
          </button>
          <button
            phx-click="inject_agent_mcp"
            phx-value-agent_id={List.first(@room_agents).id}
            phx-value-type="task_complete"
            style="padding: 7px 4px; background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.3); border-radius: 6px; font-size: 10px; font-weight: 700; color: #4ade80; cursor: pointer; text-align: center;"
          >
            🏁 Görev Bitir
          </button>
          <button
            phx-click="inject_agent_mcp"
            phx-value-agent_id={List.first(@room_agents).id}
            phx-value-type="task_fail"
            style="padding: 7px 4px; background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); border-radius: 6px; font-size: 10px; font-weight: 700; color: #f87171; cursor: pointer; text-align: center;"
          >
            ❌ Görev Hata
          </button>
        </div>
      </div>
    <% end %>

    <div style="flex: 1; min-height: 20px;"></div>
  </div>
</div>
